mod.capability('fail2ban.jail.activate')(lambda a: jail_activate(_require(a, 'jail')))
mod.capability('fail2ban.jail.deactivate')(lambda a: jail_deactivate(_require(a, 'jail')))
mod.capability('fail2ban.catalog.list')(catalog_list)
mod.capability('fail2ban.banned_ip.survey')(banned_survey)
mod.capability('fail2ban.banned_ip.focus')(banned_focus)
mod.capability('fail2ban.banned.ban')(banned_ban)
mod.capability('fail2ban.banned.unban')(banned_unban)
mod.capability('fail2ban.ignoreip.add')(lambda a: ignoreip_change(_require(a, 'jail'), _need_ip(a), True))
mod.capability('fail2ban.ignoreip.remove')(lambda a: ignoreip_change(_require(a, 'jail'), _need_ip(a), False))


@mod.capability('fail2ban.jail.set')
def _jail_set(args):
    jail = _require(args, 'jail')
    param = _arg(args, 'param')
    value = _arg(args, 'value')
    if param is None or value is None:
        raise suctlmod.CapError('INVALID_PARAMS', 'param and value are required')
    return jail_set(jail, param, value)


